# MQTT
MQTT_BROKER_HOST=192.168.1.100
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=osv-main-server

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=osv
DB_USER=osvadmin
DB_PASSWORD=osvadmin123!

# Server
HTTP_PORT=3000

# Alarm thresholds (can be overridden per device in DB)
DEFAULT_WARNING_THRESHOLD=5.0
DEFAULT_DANGER_THRESHOLD=10.0

# Watchdog: seconds before declaring comms loss
COMMS_LOSS_TIMEOUT=60
